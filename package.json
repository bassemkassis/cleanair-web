{
  "name": "cleanair-backoffice",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:prod": "astro preview --port 6000 --host 0.0.0.0",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop cleanair-web",
    "pm2:restart": "pm2 restart cleanair-web",
    "pm2:logs": "pm2 logs cleanair-web",
    "deploy": "npm run build && (pm2 restart ecosystem.config.cjs --update-env || pm2 start ecosystem.config.cjs)"
  },
  "dependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.7.0",
    "flowbite": "^3.1.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
