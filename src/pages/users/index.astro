---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Utilisateurs — CleanAir" activeNav="users">
  <div class="animate-fade-in space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Utilisateurs</h1>
        <p class="text-sm text-gray-500 mt-1">Liste des utilisateurs du système</p>
      </div>
      <div id="result-count" class="text-sm text-gray-500"></div>
    </div>

    <!-- Search -->
    <div class="section-card p-4">
      <div class="flex items-center gap-3">
        <div class="flex-1 max-w-sm">
          <input id="filter-search" type="search" placeholder="Rechercher par nom, identifiant..."
            class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-ca-primary focus:border-ca-primary outline-none bg-white" />
        </div>
      </div>
    </div>

    <!-- Table -->
    <div class="section-card p-0 overflow-hidden">
      <div id="loading" class="p-12 text-center text-gray-500">
        <div class="inline-block w-8 h-8 border-2 border-ca-primary border-t-transparent rounded-full animate-spin"></div>
        <p class="mt-3 text-sm">Chargement des utilisateurs...</p>
      </div>
      <div id="error-state" class="hidden p-12 text-center">
        <p class="text-red-600 font-medium">Impossible de charger les utilisateurs</p>
        <p id="error-msg" class="text-sm text-gray-500 mt-1"></p>
        <button id="retry-btn" class="mt-4 px-4 py-2 bg-ca-primary text-white rounded-lg text-sm">Réessayer</button>
      </div>
      <div id="empty-state" class="hidden p-12 text-center text-gray-500">
        <p class="font-medium">Aucun utilisateur trouvé</p>
      </div>
      <div id="table-wrap" class="hidden overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wider">Identifiant</th>
              <th class="px-4 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wider">Email</th>
              <th class="px-4 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wider">ID X3</th>
              <th class="px-4 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wider">Version App</th>
              <th class="px-4 py-3 font-semibold text-gray-600 text-xs uppercase tracking-wider text-center">Dernière version</th>
            </tr>
          </thead>
          <tbody id="users-body" class="divide-y divide-gray-100"></tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    import { listUsers } from '../../lib/api';
    import type { User } from '../../lib/types';

    let allUsers: User[] = [];

    const loadingEl = document.getElementById('loading')!;
    const errorEl = document.getElementById('error-state')!;
    const errorMsg = document.getElementById('error-msg')!;
    const emptyEl = document.getElementById('empty-state')!;
    const tableWrap = document.getElementById('table-wrap')!;
    const tbody = document.getElementById('users-body')!;
    const searchInput = document.getElementById('filter-search') as HTMLInputElement;
    const countEl = document.getElementById('result-count')!;

    function escapeHtml(str: string) {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    function renderTable(users: User[]) {
      loadingEl.classList.add('hidden');
      errorEl.classList.add('hidden');

      if (users.length === 0) {
        emptyEl.classList.remove('hidden');
        tableWrap.classList.add('hidden');
        countEl.textContent = '0 utilisateur';
        return;
      }

      emptyEl.classList.add('hidden');
      tableWrap.classList.remove('hidden');
      countEl.textContent = `${users.length} utilisateur${users.length > 1 ? 's' : ''}`;

      tbody.innerHTML = users.map(u => {
        const versionBadge = u.isLastVersion
          ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Oui</span>'
          : '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Non</span>';
        return `
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 font-medium text-gray-900">${escapeHtml(u.username || '—')}</td>
            <td class="px-4 py-3 text-gray-600">${escapeHtml(u.email || '—')}</td>
            <td class="px-4 py-3 text-gray-600">${escapeHtml(u.id_x3 || '—')}</td>
            <td class="px-4 py-3 text-gray-600">${escapeHtml(u.appversion || '—')}</td>
            <td class="px-4 py-3 text-center">${versionBadge}</td>
          </tr>`;
      }).join('');
    }

    function applyFilter() {
      const q = searchInput.value.trim().toLowerCase();
      if (!q) {
        renderTable(allUsers);
        return;
      }
      const filtered = allUsers.filter(u =>
        (u.fullname || '').toLowerCase().includes(q) ||
        (u.username || '').toLowerCase().includes(q) ||
        (u.id_x3 || '').toLowerCase().includes(q) ||
        (u.email || '').toLowerCase().includes(q)
      );
      renderTable(filtered);
    }

    async function load() {
      loadingEl.classList.remove('hidden');
      errorEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
      tableWrap.classList.add('hidden');

      try {
        allUsers = await listUsers();
        applyFilter();
      } catch (err: any) {
        loadingEl.classList.add('hidden');
        errorEl.classList.remove('hidden');
        errorMsg.textContent = err.message || 'Erreur inconnue';
      }
    }

    searchInput.addEventListener('input', applyFilter);
    document.getElementById('retry-btn')?.addEventListener('click', load);

    load();
  </script>
</DashboardLayout>
