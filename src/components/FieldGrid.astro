---
interface Field {
  label: string;
  value: unknown;
  mono?: boolean;
  multiline?: boolean;
  href?: string;
}
interface Props {
  fields: Field[];
  columns?: 1 | 2 | 3;
}
const { fields, columns = 2 } = Astro.props;
const gridClass = columns === 1 ? 'grid-cols-1' : columns === 3 ? 'grid-cols-1 md:grid-cols-3' : 'grid-cols-1 md:grid-cols-2';
---
<div class={`grid ${gridClass} gap-4`}>
  {fields.map((field) => (
    <div class="min-w-0">
      <div class="field-label">{field.label}</div>
      {field.href ? (
        <a href={field.href} target="_blank" rel="noopener" class="field-value text-ca-primary hover:underline">
          {String(field.value ?? '—')}
        </a>
      ) : field.multiline ? (
        <div class="field-value mt-1 p-3 bg-gray-50 rounded-lg text-sm whitespace-pre-wrap max-h-40 overflow-y-auto">
          {field.value ? String(field.value) : '—'}
        </div>
      ) : (
        <div class:list={['field-value mt-0.5', field.mono && 'font-mono text-sm']}>
          {field.value === null || field.value === undefined || field.value === '' ? '—' : String(field.value)}
        </div>
      )}
    </div>
  ))}
</div>
