---
import type { RessourceIntervention, Article, ChronometerData } from '../../lib/types';

interface Props {
  ressources?: RessourceIntervention[];
  articles?: Article[];
  chrono?: ChronometerData[];
}
const { ressources = [], articles = [], chrono = [] } = Astro.props;
---

{ressources.length > 0 ? (
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 text-xs uppercase text-gray-500">
        <tr>
          <th class="px-3 py-2 text-left">ID</th>
          <th class="px-3 py-2 text-left">Désignation</th>
          <th class="px-3 py-2 text-left">Qté</th>
          <th class="px-3 py-2 text-left">Début</th>
          <th class="px-3 py-2 text-left">Fin</th>
          <th class="px-3 py-2 text-left">Site</th>
          <th class="px-3 py-2 text-left">État</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        {ressources.map((r) => (
          <tr>
            <td class="px-3 py-2 font-mono text-xs">{r.id_ressource}</td>
            <td class="px-3 py-2">{r.designation_ressource}</td>
            <td class="px-3 py-2">{r.quantiteRessource}</td>
            <td class="px-3 py-2">{r.dateDebut} {r.heureDebut}</td>
            <td class="px-3 py-2">{r.dateFin} {r.heureFin}</td>
            <td class="px-3 py-2">{r.site_ressource}</td>
            <td class="px-3 py-2">{r.state_resource ?? '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
) : <p class="text-sm text-gray-400 text-center py-4">Aucune donnée</p>}

<!-- Articles mission -->
{articles.length > 0 && (
  <div class="mt-6">
    <h4 class="text-sm font-semibold text-gray-700 mb-2">Articles mission</h4>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-xs uppercase text-gray-500">
          <tr>
            <th class="px-3 py-2 text-left">ID</th>
            <th class="px-3 py-2 text-left">Désignation</th>
            <th class="px-3 py-2 text-left">Qté</th>
            <th class="px-3 py-2 text-left">Référence</th>
            <th class="px-3 py-2 text-left">Firmware</th>
            <th class="px-3 py-2 text-left">Logiciel</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          {articles.map((a) => (
            <tr>
              <td class="px-3 py-2 font-mono text-xs">{a.articleid}</td>
              <td class="px-3 py-2">{a.designation}</td>
              <td class="px-3 py-2">{a.quantity}</td>
              <td class="px-3 py-2">{a.reference}</td>
              <td class="px-3 py-2">{a.firmware}</td>
              <td class="px-3 py-2">{a.software}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
)}

<!-- Chrono -->
{chrono.length > 0 && (
  <div class="mt-6">
    <h4 class="text-sm font-semibold text-gray-700 mb-2">Pauses chrono</h4>
    <div class="space-y-3">
      {chrono.map((c, i) => (
        <div class="flex gap-4 p-3 bg-gray-50 rounded-lg text-sm">
          <div class="w-8 h-8 rounded-full bg-ca-primary text-white flex items-center justify-center text-xs font-bold shrink-0">{i + 1}</div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2 flex-1">
            <div><span class="text-gray-500 text-xs">Suspendu</span><div>{c.suspendedtime ?? '—'}</div></div>
            <div><span class="text-gray-500 text-xs">Reprise</span><div>{c.reviewtime ?? '—'}</div></div>
            <div><span class="text-gray-500 text-xs">% complétion</span><div>{c.percentageofcompletion ?? '—'}</div></div>
            <div><span class="text-gray-500 text-xs">Observation</span><div>{c.observation ?? '—'}</div></div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}
