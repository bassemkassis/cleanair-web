---
import '../styles/global.css';
interface Props {
  title?: string;
}
const { title = 'CleanAir Backoffice' } = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <script>
      import 'flowbite';
    </script>
  </body>
</html>
